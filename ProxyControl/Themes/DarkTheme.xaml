<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Modern Color Palette (Dark)  -->
    <Color x:Key="PrimaryAccent">#6366F1</Color>
    <Color x:Key="SecondaryAccent">#8B5CF6</Color>
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>

    <Color x:Key="SurfaceDark">#0F0F12</Color>
    <Color x:Key="SurfaceMedium">#18181B</Color>
    <Color x:Key="SurfaceLight">#27272A</Color>
    <Color x:Key="BorderColor">#3F3F46</Color>

    <!--  Text Colors  -->
    <Color x:Key="Foreground">#E4E4E7</Color>
    <Color x:Key="ForegroundMuted">#71717A</Color>
    <Color x:Key="ForegroundSubtle">#A1A1AA</Color>
    <Color x:Key="ForegroundDisabled">#52525B</Color>
    <Color x:Key="IconColor">#A1A1AA</Color>

    <!--  Brushes  -->
    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="{StaticResource PrimaryAccent}" />
    <SolidColorBrush x:Key="SecondaryAccentBrush" Color="{StaticResource SecondaryAccent}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />

    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDark}" />
    <SolidColorBrush x:Key="SurfaceMediumBrush" Color="{StaticResource SurfaceMedium}" />
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLight}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource Foreground}" />
    <SolidColorBrush x:Key="ForegroundMutedBrush" Color="{StaticResource ForegroundMuted}" />
    <SolidColorBrush x:Key="ForegroundSubtleBrush" Color="{StaticResource ForegroundSubtle}" />
    <SolidColorBrush x:Key="ForegroundDisabledBrush" Color="{StaticResource ForegroundDisabled}" />
    <SolidColorBrush x:Key="IconBrush" Color="{StaticResource IconColor}" />

    <!--  Gradient Brushes  -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#6366F1" />
        <GradientStop Offset="1" Color="#8B5CF6" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#18181B" />
        <GradientStop Offset="1" Color="#0F0F12" />
    </LinearGradientBrush>

    <!--  Minimal ScrollBar  -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#2B3442" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#8B9AB0" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#A5B4CC" />
    <SolidColorBrush x:Key="ScrollBarThumbDragBrush" Color="#C6D2E4" />
    <SolidColorBrush x:Key="ScrollBarTrackBorderBrush" Color="#445064" />

    <Style x:Key="MinimalScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MinimalScrollThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="{DynamicResource ScrollBarThumbBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border
                        x:Name="ThumbVisual"
                        Margin="0"
                        Background="{TemplateBinding Background}"
                        CornerRadius="4" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbVisual" Property="Background" Value="{DynamicResource ScrollBarThumbHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbVisual" Property="Background" Value="{DynamicResource ScrollBarThumbDragBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="VerticalMinimalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Width="{TemplateBinding Width}" Background="Transparent" SnapsToDevicePixels="True">
            <Border
                Margin="1,0"
                Background="{DynamicResource ScrollBarTrackBrush}"
                BorderBrush="{DynamicResource ScrollBarTrackBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Opacity="1" />
            <Track
                x:Name="PART_Track"
                Margin="2,2"
                Focusable="False"
                IsDirectionReversed="True"
                Orientation="Vertical">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource MinimalScrollRepeatButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb MinHeight="28" Style="{StaticResource MinimalScrollThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource MinimalScrollRepeatButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="HorizontalMinimalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Height="{TemplateBinding Height}" Background="Transparent" SnapsToDevicePixels="True">
            <Border
                Margin="0,1"
                Background="{DynamicResource ScrollBarTrackBrush}"
                BorderBrush="{DynamicResource ScrollBarTrackBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Opacity="1" />
            <Track
                x:Name="PART_Track"
                Margin="2,2"
                Focusable="False"
                IsDirectionReversed="False"
                Orientation="Horizontal">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand" Style="{StaticResource MinimalScrollRepeatButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb MinWidth="28" Style="{StaticResource MinimalScrollThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand" Style="{StaticResource MinimalScrollRepeatButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="MinWidth" Value="12" />
        <Setter Property="MinHeight" Value="12" />
        <Setter Property="Background" Value="{DynamicResource ScrollBarTrackBrush}" />
        <Setter Property="Template" Value="{StaticResource VerticalMinimalScrollBarTemplate}" />
        <Setter Property="Stylus.IsFlicksEnabled" Value="False" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="14" />
                <Setter Property="Cursor" Value="SizeNS" />
                <Setter Property="Template" Value="{StaticResource VerticalMinimalScrollBarTemplate}" />
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="14" />
                <Setter Property="Cursor" Value="SizeWE" />
                <Setter Property="Template" Value="{StaticResource HorizontalMinimalScrollBarTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
